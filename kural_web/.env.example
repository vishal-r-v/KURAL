# VITE_API_BASE_URL: Base URL of the KURAL FastAPI backend that this
# frontend talks to for every complaint filing / tracking / dashboard call.
# Must be reachable from the browser (CORS is open on the backend for this).
VITE_API_BASE_URL="http://localhost:8000"

# APP_URL: The URL where this applet is hosted (used only for self-referential
# links in the Express static host; not used for API calls).
APP_URL="http://localhost:3000"
