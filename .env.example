# KURAL Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ── Anthropic (Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use for LLM calls
# claude-haiku-4-5  = fast & cheap (recommended for demo)
# claude-sonnet-4-5 = more capable
CLAUDE_MODEL=claude-haiku-4-5

# ── NVIDIA NIM (optional — alternative LLM backend) ───────────────────────
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# ── Whisper ───────────────────────────────────────────────────────────────
# Model size: tiny | base | small | medium | large
# Live-verified: "small" gives materially better results than "base" on
# real Tanglish audio — see backend/stt.py for the language-hint rationale.
WHISPER_MODEL=small

# ── Backend ───────────────────────────────────────────────────────────────
# SQLite database file path (relative to project root or absolute)
DB_PATH=backend/kural.db

# How often (seconds) the APScheduler polls for SLA breaches (default: 60)
SLA_POLL_INTERVAL_SECONDS=60

# ── Frontend ──────────────────────────────────────────────────────────────
# URL of the FastAPI backend (for Streamlit to connect to)
KURAL_BACKEND_URL=http://localhost:8000
